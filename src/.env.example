# LogiTrack — Variáveis de ambiente (copie para .env e preencha)
# NUNCA commite o arquivo .env — ele está no .gitignore

# Google Maps Platform
GOOGLE_MAPS_API_KEY=sua_chave_aqui

# Keycloak (Auth Server)
KEYCLOAK_CLIENT_ID=logitrack-backend
KEYCLOAK_CLIENT_SECRET=seu_secret_aqui
KEYCLOAK_REALM=logitrack

# Banco de dados (gerado automaticamente pelo docker-compose)
# Não precisa alterar para ambiente local

# GCP (necessário apenas para deploy em produção)
GCP_PROJECT_ID=seu-projeto-gcp
GCP_REGION=us-central1
